# Environment Variables
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com
VITE_HELIUS_API_KEY=
VITE_DEV_MODE=true

# ---------------------------------------------------------------------------
# Backend server env (server/**, Fastify on :3001). All optional — the server
# degrades gracefully (proxy routes return empty/ok:false) when keys are absent.
# ---------------------------------------------------------------------------
# Solana RPC: if set, server uses https://mainnet.helius-rpc.com/?api-key=...
# HELIUS_API_KEY=
# Birdeye public API key (sent as X-API-KEY). Without it /api/birdeye -> { ok:false }.
# BIRDEYE_API_KEY=
# Anthropic API key (reserved for future server-side LLM alpha enrichment).
# ANTHROPIC_API_KEY=
# Smart/KOL wallet registry: "addr:name:type,addr:name:type" (type e.g. KOL, Smart Wallet).
# SMART_WALLETS=
# CORS allow-list for the API ("*" = any; or comma-separated origins).
# ALLOWED_ORIGIN=*
# Server port (frontend dev proxy expects 3001).
# PORT=3001
# Pyth Hermes base URL (default https://hermes.pyth.network).
# HERMES_URL=https://hermes.pyth.network

# --- x402 monetization gate for /api/alpha (DISABLED unless RECEIVING_WALLET set) ---
# X402_RECEIVING_WALLET=        # Solana address that receives USDC. Empty = gate off.
# X402_FACILITATOR_URL=         # Facilitator base URL exposing /verify and /settle.
# X402_ASSET=                   # USDC mint address.
# X402_PRICE=10000              # Amount in atomic units (USDC 6 decimals; 10000 = 0.01 USDC).
# X402_NETWORK=solana
